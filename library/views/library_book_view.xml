<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    
    <!-- List View -->
    <record id="view_library_book_list" model="ir.ui.view">
        <field name="name">library.book.list</field>
        <field name="model">library.book</field>
        <field name="arch" type="xml">
            <list string="Books" default_order="name asc">
                <field name="name"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'partial_available'"
                       decoration-success="state == 'available'"
                       decoration-danger="state == 'unavailable'"/>
                <field name="available_copies" string="Copies"/>
                <field name="category_id"/>
                <field name="isbn" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_library_book_form" model="ir.ui.view">
        <field name="name">library.book.form</field>
        <field name="model">library.book</field>
        <field name="arch" type="xml">
            <form string="Book">
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="available,partial_available,unavailable"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_loans"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-exchange">
                            <field name="loan_count" widget="statinfo" string="Loans"/>
                        </button>
                        <button name="action_view_reservations"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-bookmark">
                            <field name="reservation_count" widget="statinfo" string="Reservations"/>
                        </button>
                    </div>

                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="e.g. Clean Code"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Book Information">
                            <field name="authors_ids" widget="many2many_tags" options="{'no_create_edit': False}"/>
                            <field name="category_id"/>
                            <field name="isbn" placeholder="978-..."/>
                        </group>
                        <group string="Availability">
                            <field name="available_copies"/>
                            <field name="state" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

