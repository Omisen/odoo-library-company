<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    
    <!-- List View -->
    <record id="view_library_book_list" model="ir.ui.view">
        <field name="name">library.book.list</field>
        <field name="model">library.book</field>
        <field name="arch" type="xml">
            <list string="Books" default_order="name asc">
                <field name="name"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'partial_available'"
                       decoration-success="state == 'available'"
                       decoration-danger="state == 'unavailable'"/>
                <field name="available_copies" string="Copies"/>
                <field name="category_id"/>
                <field name="isbn" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_library_book_form" model="ir.ui.view">
        <field name="name">library.book.form</field>
        <field name="model">library.book</field>
        <field name="arch" type="xml">
            <form string="Book">
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="available,partial_available,unavailable"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="e.g. Clean Code"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Book Information">
                            <field name="authors_ids" widget="many2many_tags" options="{'no_create_edit': False}"/>
                            <field name="category_id"/>
                            <field name="isbn" placeholder="978-..."/>
                        </group>
                        <group string="Availability">
                            <field name="available_copies"/>
                            <field name="state" readonly="1"/>
                            <field name="loan_count" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    
    <!-- Search View -->
    <record id="view_library_book_search" model="ir.ui.view">
        <field name="name">library.book.search</field>
        <field name="model">library.book</field>
        <field name="arch" type="xml">
            <search string="Search Books">
                <field name="name"/>
                <field name="category_id"/>
                <field name="isbn"/>
                <filter name="filter_available" string="Available" domain="[('state', '=', 'available')]"/>
                <filter name="filter_partial" string="Partial" domain="[('state', '=', 'partial_available')]"/>
                <filter name="filter_unavailable" string="Unavailable" domain="[('state', '=', 'unavailable')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_by_category" string="Category" domain="[]" context="{'group_by': 'category_id'}"/>
                    <filter name="group_by_state" string="State" domain="[]" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>
    
    <!-- Action View -->
    <record id="view_library_book_action" model="ir.actions.act_window">
        <field name="name">Books</field>
        <field name="res_model">library.book</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_library_book_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Add your first book</p>
            <p>Manage titles, categories, and current availability from this menu.</p>
        </field>
    </record>
</odoo>